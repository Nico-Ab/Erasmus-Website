generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STAFF
  OFFICER
  ADMIN
}

enum UserApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DEACTIVATED
}

enum DocumentReviewState {
  PENDING_REVIEW
  ACCEPTED
  REJECTED
}

enum SelectOptionCategory {
  ACADEMIC_TITLE
  MOBILITY_TYPE
  DOCUMENT_TYPE
}

model User {
  id                        String                       @id @default(cuid())
  name                      String?
  firstName                 String?
  lastName                  String?
  academicTitleOptionId     String?
  facultyId                 String?
  departmentId              String?
  email                     String                       @unique
  emailVerified             DateTime?
  image                     String?
  passwordHash              String?
  role                      UserRole                     @default(STAFF)
  status                    UserApprovalStatus           @default(PENDING)
  reviewedAt                DateTime?
  reviewedById              String?
  academicTitleOption       SelectOption?                @relation("AcademicTitleAssignments", fields: [academicTitleOptionId], references: [id], onDelete: SetNull)
  faculty                   Faculty?                     @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  department                Department?                  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  reviewedBy                User?                        @relation("UserApprovals", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedUsers             User[]                       @relation("UserApprovals")
  mobilityCases             MobilityCase[]               @relation("StaffMobilityCases")
  mobilityCaseComments      MobilityCaseComment[]        @relation("MobilityCaseCommentAuthor")
  mobilityCaseStatusChanges MobilityCaseStatusHistory[]  @relation("MobilityCaseStatusChangedBy")
  uploadedDocumentVersions  MobilityCaseDocumentVersion[] @relation("DocumentVersionUploadedBy")
  reviewedDocumentVersions  MobilityCaseDocumentVersion[] @relation("DocumentVersionReviewedBy")
  auditEntriesActed         AuditLog[]                    @relation("AuditActor")
  auditEntriesTargeted      AuditLog[]                    @relation("AuditTargetUser")
  accounts                  Account[]
  sessions                  Session[]
  authenticators            Authenticator[]
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt

  @@index([academicTitleOptionId])
  @@index([facultyId])
  @@index([departmentId])
}

model Faculty {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String       @unique
  isActive    Boolean      @default(true)
  departments Department[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  facultyId String
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, name])
}

model AcademicYear {
  id            String         @id @default(cuid())
  label         String         @unique
  startYear     Int
  endYear       Int
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  mobilityCases MobilityCase[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([sortOrder])
}

model CaseStatusDefinition {
  id           String                      @id @default(cuid())
  key          String                      @unique
  label        String
  description  String?
  sortOrder    Int                         @default(0)
  isActive     Boolean                     @default(true)
  currentCases MobilityCase[]              @relation("CurrentCaseStatus")
  historyFrom  MobilityCaseStatusHistory[] @relation("CaseStatusHistoryFrom")
  historyTo    MobilityCaseStatusHistory[] @relation("CaseStatusHistoryTo")
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([sortOrder])
}

model SelectOption {
  id                 String                 @id @default(cuid())
  category           SelectOptionCategory
  key                String
  label              String
  sortOrder          Int                    @default(0)
  isActive           Boolean                @default(true)
  academicTitleUsers User[]                 @relation("AcademicTitleAssignments")
  caseDocuments      MobilityCaseDocument[] @relation("MobilityCaseDocumentTypeAssignments")
  mobilityTypeCases  MobilityCase[]         @relation("MobilityTypeAssignments")
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@unique([category, key])
  @@unique([category, label])
  @@index([category, sortOrder])
}

model MobilityCase {
  id                   String                      @id @default(cuid())
  staffUserId          String
  academicYearId       String?
  mobilityTypeOptionId String?
  hostInstitution      String?
  hostCountry          String?
  hostCity             String?
  startDate            DateTime?
  endDate              DateTime?
  notes                String?                     @db.Text
  statusDefinitionId   String
  submittedAt          DateTime?
  staffUser            User                        @relation("StaffMobilityCases", fields: [staffUserId], references: [id], onDelete: Cascade)
  academicYear         AcademicYear?               @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  mobilityTypeOption   SelectOption?               @relation("MobilityTypeAssignments", fields: [mobilityTypeOptionId], references: [id], onDelete: SetNull)
  statusDefinition     CaseStatusDefinition        @relation("CurrentCaseStatus", fields: [statusDefinitionId], references: [id], onDelete: Restrict)
  comments             MobilityCaseComment[]
  documents            MobilityCaseDocument[]
  statusHistory        MobilityCaseStatusHistory[]
  auditLogs            AuditLog[]
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt

  @@index([staffUserId, updatedAt])
  @@index([academicYearId])
  @@index([mobilityTypeOptionId])
  @@index([statusDefinitionId])
}

model MobilityCaseComment {
  id             String       @id @default(cuid())
  mobilityCaseId String
  authorUserId   String
  body           String       @db.Text
  mobilityCase   MobilityCase @relation(fields: [mobilityCaseId], references: [id], onDelete: Cascade)
  authorUser     User         @relation("MobilityCaseCommentAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([mobilityCaseId, createdAt])
  @@index([authorUserId])
}

model MobilityCaseStatusHistory {
  id                     String                @id @default(cuid())
  mobilityCaseId         String
  fromStatusDefinitionId String?
  toStatusDefinitionId   String
  changedByUserId        String?
  note                   String?
  mobilityCase           MobilityCase          @relation(fields: [mobilityCaseId], references: [id], onDelete: Cascade)
  fromStatusDefinition   CaseStatusDefinition? @relation("CaseStatusHistoryFrom", fields: [fromStatusDefinitionId], references: [id], onDelete: SetNull)
  toStatusDefinition     CaseStatusDefinition  @relation("CaseStatusHistoryTo", fields: [toStatusDefinitionId], references: [id], onDelete: Restrict)
  changedByUser          User?                 @relation("MobilityCaseStatusChangedBy", fields: [changedByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime              @default(now())

  @@index([mobilityCaseId, createdAt])
  @@index([fromStatusDefinitionId])
  @@index([toStatusDefinitionId])
  @@index([changedByUserId])
}

model MobilityCaseDocument {
  id                   String                        @id @default(cuid())
  mobilityCaseId       String
  documentTypeOptionId String
  currentVersionId     String?                       @unique
  mobilityCase         MobilityCase                  @relation(fields: [mobilityCaseId], references: [id], onDelete: Cascade)
  documentTypeOption   SelectOption                  @relation("MobilityCaseDocumentTypeAssignments", fields: [documentTypeOptionId], references: [id], onDelete: Restrict)
  currentVersion       MobilityCaseDocumentVersion?  @relation("CurrentDocumentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions             MobilityCaseDocumentVersion[] @relation("DocumentVersions")
  auditLogs            AuditLog[]
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt

  @@unique([mobilityCaseId, documentTypeOptionId])
  @@index([documentTypeOptionId])
  @@index([currentVersionId])
}

model MobilityCaseDocumentVersion {
  id                 String                @id @default(cuid())
  documentId         String
  versionNumber      Int
  originalFilename   String
  fileExtension      String
  mimeType           String?
  sizeBytes          Int
  storageKey         String                @unique
  reviewState        DocumentReviewState   @default(PENDING_REVIEW)
  reviewComment      String?               @db.Text
  reviewedAt         DateTime?
  reviewedByUserId   String?
  uploadedByUserId   String
  uploadedAt         DateTime              @default(now())
  document           MobilityCaseDocument  @relation("DocumentVersions", fields: [documentId], references: [id], onDelete: Cascade)
  currentForDocument MobilityCaseDocument? @relation("CurrentDocumentVersion")
  reviewedByUser     User?                 @relation("DocumentVersionReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  uploadedByUser     User                  @relation("DocumentVersionUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  auditLogs          AuditLog[]
  @@unique([documentId, versionNumber])
  @@index([reviewedByUserId])
  @@index([uploadedByUserId])
  @@index([documentId, uploadedAt])
}


model ReportSetting {
  id                         String   @id
  summaryRowLimit            Int      @default(12)
  showHostInstitutionSummary Boolean  @default(true)
  showDocumentGapSummary     Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model AuditLog {
  id                String                       @id @default(cuid())
  actorUserId       String?
  targetUserId      String?
  mobilityCaseId    String?
  documentId        String?
  documentVersionId String?
  actionType        String
  entityType        String
  entityId          String
  summary           String
  details           Json?
  actorUser         User?                        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser        User?                        @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)
  mobilityCase      MobilityCase?                @relation(fields: [mobilityCaseId], references: [id], onDelete: SetNull)
  document          MobilityCaseDocument?        @relation(fields: [documentId], references: [id], onDelete: SetNull)
  documentVersion   MobilityCaseDocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)
  createdAt         DateTime                     @default(now())

  @@index([createdAt])
  @@index([actionType, createdAt])
  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([mobilityCaseId, createdAt])
  @@index([documentId, createdAt])
  @@index([documentVersionId, createdAt])
}

model UploadSetting {
  id                String   @id
  maxUploadSizeMb   Int
  allowedExtensions String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? @db.Text
  access_token             String? @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? @db.Text
  session_state            String?
  refresh_token_expires_in Int?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}